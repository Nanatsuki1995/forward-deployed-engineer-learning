generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  AGENT
  REVIEWER
}

enum TicketStatus {
  NEW
  TRIAGE
  IN_PROGRESS
  PENDING_APPROVAL
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageRole {
  REQUESTER
  AGENT
  SYSTEM
}

enum KnowledgeStatus {
  PROCESSING
  INDEXED
  FAILED
}

enum AiLogType {
  REPLY_SUGGESTION
  SUMMARY
}

enum AuditAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  TOKEN_REFRESH
  AI_GENERATE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(AGENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTickets Ticket[]     @relation("TicketAssignee")
  requestedTickets Ticket[]    @relation("TicketRequesterUser")
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  aiLogs           AiLog[]
  notifications    Notification[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Ticket {
  id              String         @id @default(cuid())
  title           String
  description     String
  category        String         @default("未分类")
  status          TicketStatus   @default(NEW)
  priority        TicketPriority @default(MEDIUM)
  requester       String
  requesterUserId String?
  assignee        String         @default("待分派")
  assigneeUserId  String?
  tags            String[]       @default([])
  submitterName   String?
  submitterPhone  String?
  submitterEmail  String?
  source          String         @default("internal")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  requesterUser User?           @relation("TicketRequesterUser", fields: [requesterUserId], references: [id])
  assigneeUser  User?           @relation("TicketAssignee", fields: [assigneeUserId], references: [id])
  messages      TicketMessage[]
  aiLogs        AiLog[]
  notifications  Notification[]

  @@index([status])
  @@index([priority])
  @@index([updatedAt])
}

model TicketMessage {
  id        String      @id @default(cuid())
  ticketId  String
  author    String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model KnowledgeDocument {
  id        String          @id @default(cuid())
  title     String
  source    String          @default("manual-entry")
  content   String
  status    KnowledgeStatus @default(INDEXED)
  chunks    Int             @default(1)
  citations String[]        @default([])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  chunkRecords KnowledgeChunk[]

  @@index([status])
  @@index([createdAt])
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  documentId String
  position   Int
  content    String
  startOffset Int
  endOffset   Int
  embedding  Float[]
  createdAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, position])
  @@index([documentId])
}

model AiLog {
  id                    String    @id @default(cuid())
  ticketId              String
  type                  AiLogType
  promptVersion         String
  model                 String
  result                String
  confidence            Float
  citations             String[]  @default([])
  promptTokens          Int       @default(0)
  completionTokens      Int       @default(0)
  totalTokens           Int       @default(0)
  cachedPromptTokens    Int       @default(0)
  cacheMissPromptTokens Int       @default(0)
  reasoningTokens       Int       @default(0)
  apiCallCount          Int       @default(0)
  estimatedCostUsd      Float?
  actorId               String?
  createdAt             DateTime  @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([type])
  @@index([createdAt])
  @@index([actorId])
  @@index([model, createdAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  actorName  String
  actorRole  String
  action     AuditAction
  resource   String
  resourceId String?
  method     String
  path       String
  metadata   Json        @default("{}")
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  ticketId  String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
