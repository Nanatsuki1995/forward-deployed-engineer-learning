generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  AGENT
  REVIEWER
}

enum TicketStatus {
  NEW
  TRIAGE
  IN_PROGRESS
  PENDING_APPROVAL
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageRole {
  REQUESTER
  AGENT
  SYSTEM
}

enum KnowledgeStatus {
  PROCESSING
  INDEXED
  FAILED
}

enum AiLogType {
  REPLY_SUGGESTION
  SUMMARY
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(AGENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTickets Ticket[] @relation("TicketAssignee")
  requestedTickets Ticket[] @relation("TicketRequesterUser")
}

model Ticket {
  id              String         @id @default(cuid())
  title           String
  description     String
  category        String         @default("未分类")
  status          TicketStatus   @default(NEW)
  priority        TicketPriority @default(MEDIUM)
  requester       String
  requesterUserId String?
  assignee        String         @default("待分派")
  assigneeUserId  String?
  tags            String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  requesterUser User?           @relation("TicketRequesterUser", fields: [requesterUserId], references: [id])
  assigneeUser  User?           @relation("TicketAssignee", fields: [assigneeUserId], references: [id])
  messages      TicketMessage[]
  aiLogs        AiLog[]

  @@index([status])
  @@index([priority])
  @@index([updatedAt])
}

model TicketMessage {
  id        String      @id @default(cuid())
  ticketId  String
  author    String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model KnowledgeDocument {
  id        String          @id @default(cuid())
  title     String
  source    String          @default("manual-entry")
  content   String
  status    KnowledgeStatus @default(INDEXED)
  chunks    Int             @default(1)
  citations String[]        @default([])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
}

model AiLog {
  id            String    @id @default(cuid())
  ticketId      String
  type          AiLogType
  promptVersion String
  model         String
  result        String
  confidence    Float
  citations     String[]  @default([])
  createdAt     DateTime  @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([type])
  @@index([createdAt])
}
